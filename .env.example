ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# Phoenix runs locally - no additional credentials needed
# Traces are viewable at http://localhost:6006

# For GAIA benchmark with real tools
